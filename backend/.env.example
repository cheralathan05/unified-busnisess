# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digital_brain

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (required for OTP emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Digital Brain <your_email@gmail.com>"

# Redis (optional)
REDIS_URL=redis://localhost:6379

# AI
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=4500

# WebAuthn
WEBAUTHN_RP_NAME=Digital Brain
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Social Auth (optional)
FRONTEND_URL=http://localhost:3000
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Meeting Integrations (required for real links)
# Google Meet: either set a short-lived access token OR refresh-token flow vars
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Zoom: either set a short-lived access token OR Server-to-Server OAuth vars
ZOOM_ACCESS_TOKEN=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# Optional comma-separated admin emails for meeting notifications
ADMIN_NOTIFICATION_EMAILS=
